<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE components PUBLIC "-//DBFLUTE//DTD LastaDi 1.0//EN"
	"http://dbflute.org/meta/lastadi10.dtd">
<components>
	<!-- Embedding client manager -->
	<component name="embeddingClientManager" class="org.codelibs.fess.embedding.EmbeddingClientManager">
	</component>

	<!-- External embedding providers are contributed by fess-llm-* plugins via
	     fess_llm++.xml; the opensearch (ML Commons) provider below is built-in. -->
	<component name="opensearchEmbeddingClient" class="org.codelibs.fess.embedding.opensearch.OpenSearchEmbeddingClient">
		<postConstruct name="register"/>
		<postConstruct name="init"/>
		<preDestroy name="destroy"/>
	</component>
</components>
